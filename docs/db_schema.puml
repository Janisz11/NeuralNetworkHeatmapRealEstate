@startuml Database Schema

skinparam backgroundColor #030712
skinparam entityBackgroundColor #1f2937
skinparam entityBorderColor #3b82f6
skinparam fontColor #f9fafb
skinparam arrowColor #60a5fa

entity "apartments" as apt {
    *id : INTEGER <<PK, AI>>
    --
    lat : FLOAT <<NN>>
    lon : FLOAT <<NN>>
    price_per_m2 : FLOAT <<NN>>
    area_m2 : FLOAT <<NN>>
    floor : INTEGER <<NN>>
    build_year : INTEGER <<NN>>
    district : VARCHAR(100)
    created_at : TIMESTAMP <<default now()>>
    --
    INDEX ix_apartments_lat_lon (lat, lon)
}

entity "model_runs" as run {
    *id : INTEGER <<PK, AI>>
    --
    name : VARCHAR(200) <<NN>>
    epochs : INTEGER <<NN>>
    learning_rate : FLOAT <<NN>>
    hidden_layers : TEXT <<NN, JSON>>
    mse_loss : FLOAT
    r2_score : FLOAT
    weights_path : VARCHAR(500)
    status : VARCHAR(50) <<default 'pending'>>
    created_at : TIMESTAMP <<default now()>>
}

entity "users" as usr {
    *id : INTEGER <<PK, AI>>
    --
    email : VARCHAR(255) <<NN, UNIQUE>>
    name : VARCHAR(255)
    picture : VARCHAR(500)
    provider : VARCHAR(50) <<default 'google'>>
    provider_id : VARCHAR(255) <<NN>>
    role : VARCHAR(50) <<default 'admin'>>
    created_at : TIMESTAMP <<default now()>>
    --
    INDEX ix_users_email (email)
}

note bottom of apt
  Training data: 1000+ synthetic Wrocław listings
  generated by seed.py with realistic spatial clusters
end note

note bottom of run
  hidden_layers stored as JSON string e.g. "[64, 32]"
  weights_path → filesystem: weights/{id}.pt
end note

note bottom of usr
  SSO-only users; all have role='admin'
  provider field allows future OAuth providers
end note

@enduml
